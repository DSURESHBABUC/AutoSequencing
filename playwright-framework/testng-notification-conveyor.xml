<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  ╔══════════════════════════════════════════════════════════════════════════╗
  ║   TVS AutoSequencing — Notification Popup and Conveyor Hour Master Suite ║
  ║                                                                          ║
  ║   Application: https://uat-sns.tvsmotor.net/Autoseq/groupmaster         ║
  ║   Package:     com.tvsm.autoseq.tests.autoseq                           ║
  ║                                                                          ║
  ║   Run: mvn test -DsuiteXmlFile=testng-notification-conveyor.xml          ║
  ╚══════════════════════════════════════════════════════════════════════════╝
-->
<suite name="AutoSeq — Notification Popup and Conveyor Hour Master" verbose="1">

    <listeners>
        <listener class-name="com.tvsm.autoseq.listeners.TestListener"/>
        <listener class-name="com.tvsm.autoseq.confluence.ConfluenceReporter"/>
        <listener class-name="com.tvsm.autoseq.email.EmailReporter"/>
    </listeners>

    <!-- ── Notification Popup Navigation Tests ─────────────────────────── -->
    <test name="[AutoSeq] Notification Popup Tests" thread-count="1">
        <parameter name="browser"  value="chromium"/>
        <parameter name="headless" value="false"/>
        <classes>
            <class name="com.tvsm.autoseq.tests.autoseq.NotificationPopupTest"/>
        </classes>
    </test>

    <!-- ── Conveyor Hour Master Multi-Select Update Tests ──────────────── -->
    <test name="[AutoSeq] Conveyor Hour Master Tests" thread-count="1">
        <parameter name="browser"  value="chromium"/>
        <parameter name="headless" value="false"/>
        <classes>
            <class name="com.tvsm.autoseq.tests.autoseq.ConveyorHourMasterTest"/>
        </classes>
    </test>

</suite>
