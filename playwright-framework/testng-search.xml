<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Run only the Search Functionality automation tests (manualseq).

  Usage:
    mvn test -DsuiteXmlFile=testng-search.xml
-->
<suite name="ManualSeq — Search Functionality Suite" verbose="1">

    <listeners>
        <listener class-name="com.tvsm.autoseq.listeners.TestListener"/>
    </listeners>

    <test name="[ManualSeq] Search Functionality Tests" thread-count="1">
        <parameter name="browser"  value="chromium"/>
        <parameter name="headless" value="false"/>
        <classes>
            <class name="com.tvsm.autoseq.tests.manualseq.SearchFunctionalityTest"/>
        </classes>
    </test>

</suite>
